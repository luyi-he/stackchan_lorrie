+        host.slot = SPI3_HOST;
+        
+        sdspi_device_config_t slot_config = SDSPI_DEVICE_CONFIG_DEFAULT();
+        slot_config.gpio_cs = GPIO_NUM_4;
+        slot_config.host_id = SPI3_HOST;
